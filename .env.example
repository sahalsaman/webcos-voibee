# Voibee — Environment Variables

# --- Core ---
# Public base URL of the app (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- MongoDB ---
# Local: mongodb://127.0.0.1:27017/voibee
# Atlas: mongodb+srv://<user>:<pass>@cluster.mongodb.net/voibee
MONGODB_URI=mongodb://127.0.0.1:27017/voibee

# --- Auth.js (NextAuth v5) ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=replace-me-with-a-long-random-string
# Trust the host header (needed on most platforms). Keep true.
AUTH_TRUST_HOST=true

# --- Razorpay (payments) ---
# Dashboard -> Settings -> API Keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
# The key id is also exposed to the browser checkout widget:
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx

# --- Cloudinary (media uploads) ---
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=xxxxxxxxxxxxxxx
CLOUDINARY_API_SECRET=xxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
# Unsigned upload preset for client-side uploads
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=voibee_unsigned

# --- Seed (optional) ---
# Default password assigned to seeded demo accounts
SEED_PASSWORD=Password123!
